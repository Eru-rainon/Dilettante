<Page x:Class="Dilettante.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <TextBlock Text="Your Library" FontSize="22"
                           FontWeight="Bold" Foreground="White"
                           Margin="0,0,0,20"/>

                <!-- Filter + Sort bar -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ComboBox x:Name="StatusFilter" Width="140" Height="32"
              Margin="0,0,10,0" SelectedIndex="0"
              SelectionChanged="Filter_Changed"
                              Style="{StaticResource RoundedComboBox}">
                        <ComboBoxItem>All Statuses</ComboBoxItem>
                        <ComboBoxItem>Playing</ComboBoxItem>
                        <ComboBoxItem>Completed</ComboBoxItem>
                        <ComboBoxItem>Wishlisted</ComboBoxItem>
                        <ComboBoxItem>Paused</ComboBoxItem>
                        <ComboBoxItem>Abandoned</ComboBoxItem>
                    </ComboBox>

                    <ComboBox x:Name="OwnershipFilter" Width="140" Height="32"
              Margin="0,0,10,0" SelectedIndex="0"
              SelectionChanged="Filter_Changed"
                              Style="{StaticResource RoundedComboBox}">
                        <ComboBoxItem>All Ownership</ComboBoxItem>
                        <ComboBoxItem>Owned Copy</ComboBoxItem>
                        <ComboBoxItem>Subscription</ComboBoxItem>
                        <ComboBoxItem>Seafared</ComboBoxItem>
                    </ComboBox>

                    <ComboBox x:Name="SortCombo" Width="160" Height="32"
              Margin="0,0,10,0" SelectedIndex="0"
              SelectionChanged="Filter_Changed"
                              Style="{StaticResource RoundedComboBox}">
                        <ComboBoxItem>Date Added</ComboBoxItem>
                        <ComboBoxItem>Score</ComboBoxItem>
                        <ComboBoxItem>Completion %</ComboBoxItem>
                        <ComboBoxItem>Name</ComboBoxItem>
                    </ComboBox>

                    <Button x:Name="AscDescButton" Content="↓"
            Width="32" Height="32"
            Tag="desc"
            Style="{StaticResource RoundedButton}"
            Click="AscDesc_Click"/>
                </StackPanel>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText"
                           Text="No games in your library yet. Search for a game to get started."
                           Foreground="#8899aa" FontSize="13"
                           Visibility="Collapsed"/>

                <!-- Games grid -->
                <ItemsControl x:Name="GamesPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,0,4,16"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="GameCard_Click">
                                <StackPanel>

                                    <!-- Image with overlays -->
                                    <Grid Height="120">

                                        <!-- Header image -->
                                        <Image Source="{Binding HeaderImageUrl}"
                                               Stretch="UniformToFill"/>

                                        <!-- Dark overlay -->
                                        <Rectangle Opacity="0.3">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="Black"/>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- Achievement % — top right -->
                                        <Border Width="40" Height="40"
                                                CornerRadius="20"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,6,6,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding CompletionText}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- User score — bottom left -->
                                        <Border Width="40" Height="40"
                                                CornerRadius="20"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Margin="6,0,0,6">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding UserScore}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Status icon — bottom right -->
                                        <Border Width="34" Height="34"
                                                CornerRadius="17"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,6,6">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Ownership icon — top left -->
                                        <Border Width="34" Height="34"
                                                CornerRadius="17"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="6,6,0,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding OwnershipIcon}"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                    </Grid>

                                    <!-- Game name below image -->
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>