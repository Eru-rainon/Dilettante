<Page x:Class="Dilettante.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <TextBlock Text="Your Library" FontSize="22"
                           FontWeight="Bold" Foreground="White"
                           Margin="0,0,0,20"/>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText"
                           Text="No games in your library yet. Search for a game to get started."
                           Foreground="#8899aa" FontSize="13"
                           Visibility="Collapsed"/>

                <!-- Games grid -->
                <ItemsControl x:Name="GamesPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Margin="0,0,16,16"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="GameCard_Click">
                                <StackPanel>

                                    <!-- Image with overlays -->
                                    <Grid Width="200" Height="94">

                                        <!-- Header image -->
                                        <Image Source="{Binding HeaderImageUrl}"
                                               Stretch="UniformToFill"
                                               Width="200" Height="94"/>

                                        <!-- Dark overlay -->
                                        <Rectangle Opacity="0.3">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="Black"/>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- Achievement % — top right -->
                                        <Border Width="36" Height="36"
                                                CornerRadius="18"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,6,6,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding CompletionText}"
                                                       Foreground="White"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Status icon — bottom right -->
                                        <Border Width="30" Height="30"
                                                CornerRadius="15"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,6,6">
                                            <Border.Background>
                                                <SolidColorBrush Color="#CC000000"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                    </Grid>

                                    <!-- Game name below image -->
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>