<Page x:Class="Dilettante.Pages.AchievementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- Title -->
                <TextBlock x:Name="PageTitle" FontSize="24"
                           FontWeight="Bold" Foreground="White"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="ProgressText" FontSize="13"
                           Foreground="#8899aa" Margin="0,0,0,20"/>

                <!-- Save button -->
                <Button x:Name="ToggleAllButton"
                            Content="Select All"
                            Width="180" Height="38"
                            HorizontalAlignment="Left"
                            Margin="0,2,0,16"
                            Style="{StaticResource RoundedButton}"
                            Click="ToggleAll"/>

                <!-- Achievement list -->
                <ItemsControl x:Name="AchievementList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border  CornerRadius="8"
                                    Margin="0,0,0,8" Padding="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#0d1f30"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0a1828"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsUnlocked, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Cursor="Hand"
                                              Checked="CheckBoxToggle"
                                              Unchecked="CheckBoxToggle"/>

                                    <!-- Icon -->
                                    <Image Grid.Column="1"
                                           Source="{Binding IconUrl}"
                                           Width="32" Height="32"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="ToggleAchievement"/>

                                    <!-- Name + Description -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="White" FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Cursor="Hand"
                                                   MouseLeftButtonUp="ToggleAchievement"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#8899aa" FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Cursor="Hand"
                                                   MouseLeftButtonUp="ToggleAchievement"/>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Save button -->
                <Button x:Name="SaveAchievementsButton"
                        Content="Save Achievements"
                        Width="180" Height="38"
                        HorizontalAlignment="Left"
                        Margin="0,16,0,0"
                        Style="{StaticResource RoundedButton}"
                        Click="SaveAchievementsButton_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>