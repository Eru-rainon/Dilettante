<Window x:Class="Dilettante.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dilettante" Height="180" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="12" BorderBrush="#2a4a6a" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0d2137" Offset="0"/>
                <GradientStop Color="#0a1628" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText" Grid.Row="0"
               FontSize="14" Foreground="White"
               TextWrapping="Wrap"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel"
                Width="90" Height="34" Margin="0,0,10,0"
                Style="{StaticResource RoundedButton}"
                Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton" Content="Delete"
                Width="90" Height="34"
                Background="#c0392b"
                Style="{StaticResource RoundedButton}"
                Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>